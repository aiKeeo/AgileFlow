# atlas/agileflow.env — Agileflow 流程状态（AI 维护 · 闸门必读）
# 不是密钥文件；须提交进仓库。改决策/进阶后立即更新，否则 validate-atlas 报错卡住。
#
# ⚠ 首启：禁止照抄本模板的 ai 当「已确认」。
#    无 env 或 AF_DECIDE=pending → 先发「流程启动卡」AskQuestion → 停；
#    用户选定后再写入真实值。用户原话已点明委托（你定/别问我）才可跳过启动卡。
#
# AF_STEP      当前 flow 步 id，或并行波 id1,id2（有 flow 时必填）
# AF_PHASE     闸门档 0=init 1=req 2=mod 3=sol 4=dev 5=tests（=波最左步的 band，须与 AF_STEP 同步）
# AF_DECIDE    ai=AI自主 | user=用户决策 | pending=尚未问用户（闸门必挡）
# AF_TIER      固定 full（唯一质量档位）
# AF_STACK_SOURCE  技术栈来源（阶段 3 起必填语义）：
#   pending     = 尚未选定（user 模式 sol-confirm 必挡）
#   ai_record   = AI自主已写入「AI 决策记录」
#   askquestion = 用户经技术栈 AskQuestion 选定
#   user_said   = 用户原话指定完整栈
#   repo        = 沿用仓库已有栈
#
# AF_HOST_CAPABILITY  宿主 Subagent 能力（总控首条回复根据 tool list 写，非 bootstrap 探测）：
#   pending     = 尚未声明（跑 --gate 必挡）
#   full        = 有 Subagent/Task（Cursor=Task）；台账须 normal + subagentId
#   degraded    = 确无 Subagent API；台账可 degraded-single-session + degradedReason
#
# AF_TEMPLATE    文档形态开关：
#   no          = 默认 legacy 形态（v9.11 及之前，使用 skill templates/ 提示词）
#   yes         = Template ON（启用 atlas/template/ 下项目模板，走 validateGenericDocs 路径）
#   改决策/进阶后应立即更新，否则 validate-atlas 可能报错。

AF_STEP=req
AF_PHASE=1
AF_DECIDE=pending
AF_TIER=full
AF_STACK_SOURCE=pending
AF_HOST_CAPABILITY=pending
AF_TEMPLATE=no
