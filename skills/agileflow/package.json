{
  "name": "agileflow-validate",
  "version": "9.21.0",
  "private": true,
  "description": "Agileflow atlas 校验（fe-pixel 去冗余）",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-atlas.mjs",
    "validate:gates": "node scripts/validate-atlas.mjs --list-gates",
    "validate:init": "node scripts/validate-atlas.mjs --gate init-confirm",
    "validate:req": "node scripts/validate-atlas.mjs --gate req-confirm",
    "validate:mod": "node scripts/validate-atlas.mjs --gate mod-confirm",
    "validate:sol": "node scripts/validate-atlas.mjs --gate sol-confirm",
    "validate:dev": "node scripts/validate-atlas.mjs --gate dev-complete",
    "validate:test": "node scripts/validate-atlas.mjs --gate test-entry",
    "print:skill-root": "node scripts/validate-atlas.mjs --print-skill-root",
    "fe-pixel": "node scripts/fe-pixel/fe-pixel.mjs",
    "test:validate": "node scripts/validate-atlas/test-fixtures.mjs && node scripts/validate-atlas/test-af-env.mjs && node scripts/validate-atlas/test-template-mode.mjs && node scripts/validate-atlas/test-doc-consistency.mjs && node scripts/validate-atlas/test-skill-examples.mjs",
    "test:af-env": "node scripts/validate-atlas/test-af-env.mjs",
    "test:docs": "node scripts/validate-atlas/test-doc-consistency.mjs",
    "retest:prepare": "node scripts/agent-retest/prepare.mjs",
    "retest:score": "node scripts/agent-retest/score.mjs"
  }
}
