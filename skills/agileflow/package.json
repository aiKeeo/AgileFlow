{
  "name": "@agileflow/cli",
  "version": "1.1.0",
  "description": "AgileFlow CLI：init 挂载门牌 skill + validate-atlas 闸门",
  "type": "module",
  "bin": {
    "agileflow": "./bin/agileflow.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "cli/adapters",
    "cli/snippets",
    "cli/workflows",
    "cli/af-log.mjs",
    "cli/body-for-entry.mjs",
    "cli/catalog.mjs",
    "cli/generate.mjs",
    "cli/init.mjs",
    "cli/package-meta.mjs",
    "cli/parse-argv.mjs",
    "cli/resolve-project-skill-root.mjs",
    "cli/runtime-command.mjs",
    "cli/step-sync.mjs",
    "cli/sync-skill-tree.mjs",
    "scripts/fe-pixel",
    "scripts/runtime",
    "scripts/validate-atlas.mjs",
    "scripts/validate-atlas/index.mjs",
    "scripts/validate-atlas/lib",
    "templates",
    "phases",
    "presets",
    "tools/fe-pixel-compare.md",
    "tools/fe-smoke-playwright.md",
    "examples/dev-exemplar-BE.md",
    "examples/dev-exemplar-FE.md",
    "examples/dev-reuse-examples.md",
    "examples/flow-interaction.md",
    "SKILL.md",
    "majorflow.md",
    "QUICKSTART.md",
    "TROUBLESHOOTING.md",
    "package.json"
  ],
  "scripts": {
    "agileflow": "node bin/agileflow.mjs",
    "validate": "node scripts/validate-atlas.mjs",
    "validate:gates": "node scripts/validate-atlas.mjs --list-gates",
    "validate:init": "node scripts/validate-atlas.mjs --gate init-confirm",
    "validate:req": "node scripts/validate-atlas.mjs --gate req-confirm",
    "validate:mod": "node scripts/validate-atlas.mjs --gate mod-confirm",
    "validate:sol": "node scripts/validate-atlas.mjs --gate sol-confirm",
    "validate:dev": "node scripts/validate-atlas.mjs --gate dev-complete",
    "validate:test": "node scripts/validate-atlas.mjs --gate test-entry",
    "print:skill-root": "node scripts/validate-atlas.mjs --print-skill-root",
    "fe-pixel": "node scripts/fe-pixel/fe-pixel.mjs",
    "test:cli": "node cli/test-init.mjs",
    "test:runtime": "node cli/test-runtime.mjs && node cli/test-gate-runtime.mjs && node scripts/validate-atlas/test-gate-receipts.mjs && node scripts/agent-retest/test-score.mjs",
    "test:validate": "node scripts/validate-atlas/test-fixtures.mjs && node scripts/validate-atlas/test-af-env.mjs && node scripts/validate-atlas/test-req-ac-backfill.mjs && node scripts/validate-atlas/test-template-mode.mjs && node scripts/validate-atlas/test-doc-consistency.mjs && node scripts/validate-atlas/test-skill-examples.mjs && node scripts/validate-atlas/test-flow.mjs && node scripts/validate-atlas/test-scope.mjs && node scripts/validate-atlas/test-af-commands.mjs && node scripts/validate-atlas/test-gate-receipts.mjs && node cli/test-init.mjs && node cli/test-runtime.mjs && node cli/test-gate-runtime.mjs && node scripts/agent-retest/test-score.mjs",
    "test:af-env": "node scripts/validate-atlas/test-af-env.mjs",
    "test:docs": "node scripts/validate-atlas/test-doc-consistency.mjs",
    "sync:fixture-baselines": "node scripts/validate-atlas/sync-fixture-role-baselines.mjs",
    "retest:prepare": "node scripts/agent-retest/prepare.mjs",
    "retest:score": "node scripts/agent-retest/score.mjs"
  }
}
