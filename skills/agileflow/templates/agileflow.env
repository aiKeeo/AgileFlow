# atlas/agileflow.env — Agileflow 流程状态（AI 维护 · 闸门必读）
# 不是密钥文件；须提交进仓库。改决策/进阶后立即更新，否则 validate-atlas 报错卡住。
#
# ⚠ 首启：禁止照抄本模板的 fast/ai 当「已确认」。
#    无 env 或 AF_FLOW/AF_DECIDE=pending → 先发「流程启动卡」AskQuestion → 停；
#    用户选定后再写入真实值。用户原话已同时点明两边（如「快速+你定」）才可跳过启动卡。
#
# AF_PHASE     当前主阶段 0=init 1=req 2=mod 3=sol 4=dev 5=tests
# AF_FLOW      fast=快速 | strict=严谨 | pending=尚未问用户（闸门必挡）
# AF_DECIDE    ai=AI自主 | user=用户决策 | pending=尚未问用户（闸门必挡）
# AF_TIER      lite|standard|full（dev 文档默认档；完整档强制机械 grep）
# AF_STACK_SOURCE  技术栈来源（阶段 3 起必填语义）：
#   pending     = 尚未选定（user 模式 sol-confirm 必挡）
#   ai_record   = AI自主已写入「AI 决策记录」
#   askquestion = 用户经技术栈 AskQuestion 选定
#   user_said   = 用户原话指定完整栈
#   repo        = 沿用仓库已有栈

AF_PHASE=1
AF_FLOW=pending
AF_DECIDE=pending
AF_TIER=standard
AF_STACK_SOURCE=pending
